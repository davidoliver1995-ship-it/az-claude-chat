# AZ AI Gateway Configuration
AI_GATEWAY_URL=https://ai-gateway.astrazeneca.net/bedrock
AI_GATEWAY_KEY=your-az-gateway-key-here

# Optional: change model (default is Claude Opus 4.5)
CLAUDE_MODEL=us.anthropic.claude-opus-4-5-20251101-v1:0

# Server port (default 3737)
PORT=3737

# Tavily API for web search (optional)
TAVILY_API_KEY=your-tavily-key-here
