#!/usr/bin/env osascript

set appDir to (POSIX path of (path to home folder)) & "az-claude-chat"
set serverFile to appDir & "/server.js"

-- Check project exists
try
  do shell script "test -f " & quoted form of serverFile
on error
  display alert "AZ Claude Chat" message "Project not found at ~/az-claude-chat. Please clone the repo first." as critical
  return
end try

-- Check .env exists  
try
  do shell script "test -f " & quoted form of (appDir & "/.env")
on error
  do shell script "cp " & quoted form of (appDir & "/.env.example") & " " & quoted form of (appDir & "/.env")
  display alert "Setup Required" message "Add your AI_GATEWAY_KEY to ~/.az-claude-chat/.env then relaunch." buttons {"Open File"} default button "Open File"
  do shell script "open -a TextEdit " & quoted form of (appDir & "/.env")
  return
end try

-- Kill existing server
try
  do shell script "lsof -ti:3737 | xargs kill -9 2>/dev/null; true"
end try

-- Start server
do shell script "/usr/local/bin/node " & quoted form of (appDir & "/server.js") & " > /tmp/az-claude-chat.log 2>&1 &"

delay 2

-- Open browser
do shell script "open http://localhost:3737"

display notification "AZ Claude Chat running at localhost:3737" with title "AZ Claude"
