#!/usr/bin/env osascript

-- Kill any existing server on port 3737
try
  do shell script "lsof -ti:3737 | xargs kill -9 2>/dev/null; true"
end try

delay 1

-- Start server via Terminal so it stays running and env vars load properly
tell application "Terminal"
  activate
  do script "cd ~/az-claude-chat && node server.js"
end tell

delay 3

-- Open browser
do shell script "open http://localhost:3737"
